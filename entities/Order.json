{
  "name": "Order",
  "type": "object",
  "properties": {
    "order_number": { "type": "string", "description": "Numero de orden" },
    "customer_name": { "type": "string", "minLength": 1, "description": "Nombre del cliente" },
    "customer_email": { "type": "string", "format": "email", "description": "Email del cliente" },
    "customer_phone": { "type": "string", "description": "Telefono del cliente" },
    "shipping_address": { "type": "string", "description": "Direccion de envio" },
    "shipping_city": { "type": "string", "description": "Ciudad" },
    "shipping_state": { "type": "string", "description": "Estado" },
    "shipping_zip": { "type": "string", "description": "Codigo postal" },
    "items": { "type": "array", "items": { "type": "object" }, "description": "Items del pedido" },
    "subtotal": { "type": "number", "minimum": 0, "description": "Subtotal" },
    "shipping_cost": { "type": "number", "minimum": 0, "default": 0, "description": "Costo de envio" },
    "total": { "type": "number", "minimum": 0, "description": "Total" },
    "currency": { "type": "string", "enum": ["MXN", "USD"], "default": "MXN" },
    "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered", "cancelled"], "default": "pending" },
    "payment_method": { "type": "string", "enum": ["cash", "card", "transfer"], "default": "transfer" },
    "notes": { "type": "string", "description": "Notas del pedido" }
  },
  "required": ["customer_name", "customer_phone", "items", "total"]
}
